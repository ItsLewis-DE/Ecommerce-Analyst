{
    "LambdaFunctionConfigurations": [
        {
            "Id": "trigger-users",
            "LambdaFunctionArn": "arn:aws:lambda:us-east-1:000000000000:function:users_trans",
            "Events": ["s3:ObjectCreated:*"],
            "Filter": {
                "Key": {
                    "FilterRules": [
                        {"Name": "prefix", "Value": "users/"}
                    ]
                }
            }
        },
